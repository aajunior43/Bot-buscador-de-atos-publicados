# =============================================================================
# Monitor de Atos — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores.
# =============================================================================

# -----------------------------------------------------------------------------
# Site do jornal
# -----------------------------------------------------------------------------
SITE_URL=https://www.oregionaljornal.com.br/edicoes/
USER_AGENT=Mozilla/5.0 (compatible; JornalMonitor/1.0; +https://www.oregionaljornal.com.br/)

# -----------------------------------------------------------------------------
# Telegram
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxYZ
TELEGRAM_CHAT_ID=-100123456789

# -----------------------------------------------------------------------------
# SMTP / E-mail
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_de_app
SMTP_FROM=seu@email.com
SMTP_TO=destino@email.com

# Envia e-mail de cópia mesmo quando o Telegram teve sucesso (padrão: false)
NOTIFY_EMAIL_ALWAYS=false

# -----------------------------------------------------------------------------
# Webhook genérico (POST JSON com resumo da detecção)
# -----------------------------------------------------------------------------
WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Banco de dados e diretórios
# -----------------------------------------------------------------------------
DB_PATH=./jornal_monitor.db
DOWNLOAD_DIR=./edicoes
ALERT_DIR=./alertas
LOG_DIR=./logs

# Pasta organizada de atos (ano/mês/dia + atalhos por tipo e órgão)
ATOS_DIR=./atos
ATOS_ESPELHAR=true
ATOS_POR_TIPO=true
ATOS_POR_ORGAO=true

# -----------------------------------------------------------------------------
# Ciclo de verificação
# -----------------------------------------------------------------------------
CHECK_INTERVAL_HOURS=6

# Limite de edições novas processadas por ciclo (evita sobrecarga no 1º uso)
MAX_EDICOES_POR_CICLO=10

# -----------------------------------------------------------------------------
# Automação (ciclo único: WEB varre, BOT processa)
# -----------------------------------------------------------------------------
# WEB (webapp): só detecta/cadastra edições a cada WEB_SCAN_INTERVAL_HOURS
# BOT (main.py): OCR + IA + alertas a cada CHECK_INTERVAL_HOURS
# true = BOT processa pendentes sozinho (recomendado)
AUTO_PROCESS=true
# Tamanho de cada lote de OCR na fila
AUTO_PROCESS_LIMIT=5
# No ciclo completo (a cada CHECK_INTERVAL), processa até N da fila (vários lotes)
AUTO_PROCESS_MAX_POR_CICLO=40
# true = entre ciclos continua esvaziando a fila (recomendado)
AUTO_PROCESS_CONTINUO=true
# Só auto-processa edições dos últimos N dias (0 = sem esse filtro)
AUTO_PROCESS_DIAS=0
# Data mínima (YYYY-MM-DD). Ex.: 2020-01-01 = ignora edições de 2011–2019
AUTO_PROCESS_DESDE=2020-01-01
# Após N falhas de download/OCR a edição sai da fila (quarentena)
AUTO_PROCESS_MAX_FALHAS=3
# Intervalo da varredura do webapp (horas) — apenas cadastro de URLs
WEB_SCAN_INTERVAL_HOURS=6

# -----------------------------------------------------------------------------
# Rede
# -----------------------------------------------------------------------------
REQUEST_TIMEOUT_SECONDS=45
MAX_RETRIES=3

# -----------------------------------------------------------------------------
# OCR (Tesseract)
# -----------------------------------------------------------------------------
OCR_LANGUAGE=por
FORCE_OCR=false
OCR_DPI=200
OCR_RETRY_DPI=250
OCR_MAX_DIMENSION=3200
OCR_FAST_DPI=120
OCR_FAST_MIN_CHARS=300
OCR_FAST_MAX_DIMENSION=1800
OCR_TIMEOUT_SECONDS=120
OCR_FAST_TIMEOUT_SECONDS=120
OCR_LAYOUT_COLUMNS=3
MIN_TEXT_CHARS_PER_PAGE=100
# Paralelismo OCR: 0 = automático (cores-1, deixa 1 núcleo livre)
OCR_MAX_WORKERS=0
OCR_MIN_WORKERS=1
# true = mede CPU e escolhe workers de forma conservadora
OCR_ADAPTIVE_CPU=true
# Alvo ~70% (nunca mira 100%; cap interno 80%)
OCR_CPU_TARGET=0.70

# Caminho para o executável do Tesseract (necessário no Windows)
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# Caminho para os binários do Poppler (necessário no Windows)
POPPLER_PATH=C:\poppler\Library\bin

# -----------------------------------------------------------------------------
# Ambiente e autenticação da interface web (HTTP Basic)
# -----------------------------------------------------------------------------
# development | production
# Em production o webapp recusa subir sem WEBAPP_USER e WEBAPP_PASSWORD.
APP_ENV=development

# Força exigência de credenciais mesmo fora de production.
REQUIRE_WEBAPP_AUTH=false

# Defina AMBOS para proteger a interface (/admin, rotas de ação e API).
# Em host público / Docker com Traefik, use APP_ENV=production ou REQUIRE_WEBAPP_AUTH=true.
WEBAPP_USER=admin
WEBAPP_PASSWORD=troque-esta-senha

# -----------------------------------------------------------------------------
# IA (OpenCode / OpenRouter)
# -----------------------------------------------------------------------------
OPENCODE_API_KEY=sk-...
OPENCODE_API_URL=https://opencode.ai/zen/go/v1/chat/completions
OPENCODE_MODEL=deepseek-v4-flash
AI_REFINE_PUBLICATIONS=true
AI_TIMEOUT_SECONDS=30
AI_MAX_TOKENS=8000

# -----------------------------------------------------------------------------
# Detecção — termos e CEPs de Inajá
# -----------------------------------------------------------------------------
# Termos extras além dos padrões (separados por vírgula)
INAJA_EXTRA_TERMS=

# Prefixos de CEP de Inajá (padrão: 87670)
INAJA_CEP_PREFIXES=87670

# Termos de contexto que indicam menção irrelevante (separados por vírgula)
# Deixe vazio para usar os padrões (panificadora, farmácia, etc.)
INAJA_IGNORE_CONTEXT_TERMS=

# -----------------------------------------------------------------------------
# Alertas de ausência de publicação
# -----------------------------------------------------------------------------
# Envia alerta se nenhuma publicação for detectada nos últimos N dias
ABSENCE_ALERT_DAYS=30
